<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/themeBgDark">

    <!-- Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbarProfile"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBackProfile"
            android:layout_width="@dimen/icon_size_default"
            android:layout_height="@dimen/icon_size_default"
            android:src="@android:drawable/ic_menu_revert"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/themeTextWhite" />

        <TextView
            android:id="@+id/tvProfileTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_l"
            android:text="@string/title_profile"
            android:textColor="?attr/themeTextWhite"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnBackProfile"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarProfile">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Avatar -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivProfileAvatar"
                android:layout_width="@dimen/avatar_large"
                android:layout_height="@dimen/avatar_large"
                android:layout_marginTop="@dimen/spacing_l"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery"
                app:shapeAppearanceOverlay="@style/CircleImage"
                app:strokeColor="?attr/themePrimary"
                app:strokeWidth="2dp" />

            <TextView
                android:id="@+id/btnChangeAvatar"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="@dimen/spacing_m"
                android:background="@drawable/btn_outline"
                android:backgroundTint="?attr/themePrimary"
                android:gravity="center"
                android:paddingHorizontal="24dp"
                android:text="@string/profile_change_avatar"
                android:textColor="?attr/themeTextWhite"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnRemoveAvatar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:padding="@dimen/spacing_s"
                android:text="@string/profile_remove_avatar"
                android:textColor="@color/red_stop"
                android:textSize="13sp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/spacing_xl"
                android:layout_marginBottom="@dimen/spacing_xl"
                android:background="?attr/themeNavBg" />

            <!-- Tên hiển thị -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/profile_display_name_label"
                android:textColor="?attr/themeTextSecondary"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/etDisplayName"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_default"
                android:layout_marginTop="@dimen/spacing_s"
                android:background="@drawable/btn_outline"
                android:hint="@string/profile_display_name_hint"
                android:inputType="textPersonName"
                android:paddingHorizontal="16dp"
                android:textColor="?attr/themeTextWhite"
                android:textColorHint="?attr/themeTextSecondary"
                android:textSize="16sp" />

            <!-- Email -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_l"
                android:text="@string/profile_email_label"
                android:textColor="?attr/themeTextSecondary"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_default"
                android:layout_marginTop="@dimen/spacing_s"
                android:background="@drawable/btn_outline"
                android:hint="@string/profile_email_hint"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="16dp"
                android:textColor="?attr/themeTextWhite"
                android:textColorHint="?attr/themeTextSecondary"
                android:textSize="16sp" />

            <!-- Ghi chú cá nhân -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_l"
                android:text="@string/profile_bio_label"
                android:textColor="?attr/themeTextSecondary"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/etBio"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="@dimen/spacing_s"
                android:background="@drawable/btn_outline"
                android:gravity="top|start"
                android:hint="@string/profile_bio_hint"
                android:inputType="textMultiLine"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp"
                android:textColor="?attr/themeTextWhite"
                android:textColorHint="?attr/themeTextSecondary"
                android:textSize="16sp" />

            <!-- Nút lưu -->
            <TextView
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_default"
                android:layout_marginTop="32dp"
                android:background="@drawable/btn_outline"
                android:backgroundTint="?attr/themePrimary"
                android:gravity="center"
                android:text="@string/profile_save_button"
                android:textColor="?attr/themeTextWhite"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
