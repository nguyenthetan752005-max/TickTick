<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/ic_launcher_background"
        android:backgroundTint="#1C1C1E"
        android:orientation="vertical"
        android:padding="24dp">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            android:background="#33FFFFFF" />

        <!-- Thêm ID tvDialogTitle để Java có thể đổi tên -->
        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nhiệm vụ mới"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etTaskName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@android:color/transparent"
            android:hint="Bạn muốn làm gì?"
            android:textColor="@color/white"
            android:textColorHint="#8E8E93"
            android:textSize="20sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etTaskDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@android:color/transparent"
            android:hint="Thêm chi tiết..."
            android:textColor="#EBEBF5"
            android:textColorHint="#4DFFFFFF"
            android:textSize="16sp" />

        <!-- Khu vực nhắc nhở -->
        <LinearLayout
            android:id="@+id/layoutReminderSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <!-- Nút thêm nhắc nhở -->
            <LinearLayout
                android:id="@+id/btnAddReminder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/btn_outline"
                android:backgroundTint="#2C2C2E"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_lock_idle_alarm"
                    app:tint="@color/blue_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Thêm nhắc nhở"
                    android:textColor="@color/blue_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Container hiển thị danh sách reminders đã thêm -->
            <LinearLayout
                android:id="@+id/layoutReminderList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnClearDeadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="8dp"
            android:text="Xóa hạn chót"
            android:textColor="@color/design_default_color_error"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="24dp"
            android:background="#33FFFFFF" />

        <!-- Hàng 1: Ngày, Giờ, Danh mục -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/btnDateContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/btn_outline"
                android:backgroundTint="#2C2C2E"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_today"
                    app:tint="@color/blue_primary" />

                <TextView
                    android:id="@+id/tvDueDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Hôm nay"
                    android:textColor="@color/blue_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="6dp"
                android:layout_height="0dp" />

            <!-- Nút chọn giờ -->
            <LinearLayout
                android:id="@+id/btnTimeContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/btn_outline"
                android:backgroundTint="#2C2C2E"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_recent_history"
                    app:tint="@color/blue_primary" />

                <TextView
                    android:id="@+id/tvDueTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="00:00"
                    android:textColor="@color/blue_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="6dp"
                android:layout_height="0dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/btn_outline"
                android:backgroundTint="#2C2C2E"
                android:gravity="center_vertical"
                android:paddingHorizontal="8dp"
                android:paddingVertical="6dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_directions"
                    app:tint="#EBEBF5" />

                <Spinner
                    android:id="@+id/spCategory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:dropDownWidth="200dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Hàng 2: Nút Hủy và Nút Lưu -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCancelTask"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#2C2C2E"
                android:text="Hủy"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnSaveTask"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/ic_launcher_background"
                android:backgroundTint="@color/blue_primary"
                android:src="@android:drawable/ic_menu_send"
                app:tint="@color/white" />

        </LinearLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>