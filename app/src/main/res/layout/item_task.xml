<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardTask"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_l"
    android:layout_marginVertical="@dimen/spacing_s"
    app:cardBackgroundColor="?attr/themeNavBg"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:id="@+id/layoutTaskItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_l"
        android:gravity="center_vertical">

        <!-- Checkbox ô tròn -->
        <ImageView
            android:id="@+id/ivCheckbox"
            android:layout_width="@dimen/icon_size_default"
            android:layout_height="@dimen/icon_size_default"
            android:src="@android:drawable/checkbox_off_background"
            app:tint="?attr/themeTextSecondary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_l"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTaskName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/task_item_name_placeholder"
                android:textColor="?attr/themeTextWhite"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTaskDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/task_item_desc_placeholder"
                android:textColor="?attr/themeTextSecondary"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvTaskDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:textColor="?attr/themePrimary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Icon để đánh dấu đang chọn trong Multi-select mode -->
        <ImageView
            android:id="@+id/ivSelected"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/checkbox_on_background"
            android:visibility="gone"
            app:tint="?attr/themePrimary" />

    </LinearLayout>
</androidx.cardview.widget.CardView>