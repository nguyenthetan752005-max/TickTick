<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/themeCardDark"
    android:layout_marginHorizontal="@dimen/spacing_m"
    android:layout_marginVertical="@dimen/spacing_s"
    android:paddingHorizontal="@dimen/spacing_l"
    android:paddingVertical="@dimen/spacing_m">

    <!-- Avatar Circle -->
    <TextView
        android:id="@+id/tvAvatar"
        android:layout_width="@dimen/avatar_small"
        android:layout_height="@dimen/avatar_small"
        android:background="@drawable/item_circle_bg"
        android:gravity="center"
        android:textColor="?attr/themeTextWhite"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Name -->
    <TextView
        android:id="@+id/tvContactName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_m"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="?attr/themeTextWhite"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/tvContactPhone"
        app:layout_constraintEnd_toStartOf="@id/btnCall"
        app:layout_constraintStart_toEndOf="@id/tvAvatar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- Phone -->
    <TextView
        android:id="@+id/tvContactPhone"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_m"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="?attr/themeTextSecondary"
        android:textSize="13sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnCall"
        app:layout_constraintStart_toEndOf="@id/tvAvatar"
        app:layout_constraintTop_toBottomOf="@id/tvContactName" />

    <!-- Call Button -->
    <ImageView
        android:id="@+id/btnCall"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="@dimen/spacing_m"
        android:background="@drawable/item_circle_bg"
        android:backgroundTint="@color/green_call"
        android:padding="8dp"
        android:src="@android:drawable/sym_action_call"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnSms"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="?attr/themeTextWhite" />

    <!-- SMS Button -->
    <ImageView
        android:id="@+id/btnSms"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/item_circle_bg"
        android:backgroundTint="@color/orange_sms"
        android:padding="8dp"
        android:src="@android:drawable/sym_action_email"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="?attr/themeTextWhite" />

</androidx.constraintlayout.widget.ConstraintLayout>
