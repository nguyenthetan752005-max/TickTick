<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/ic_launcher_background"
    android:backgroundTint="#1C1C1E"
    android:orientation="vertical"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="#33FFFFFF" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔔 Thêm nhắc nhở"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Nhắc nhở trước deadline:"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Nhập số lượng -->
        <EditText
            android:id="@+id/etReminderValue"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/btn_outline"
            android:backgroundTint="#2C2C2E"
            android:gravity="center"
            android:hint="30"
            android:inputType="number"
            android:textColor="@color/white"
            android:textColorHint="#4DFFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingHorizontal="12dp" />

        <View
            android:layout_width="12dp"
            android:layout_height="0dp" />

        <!-- Chọn đơn vị -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="2"
            android:background="@drawable/btn_outline"
            android:backgroundTint="#2C2C2E"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp">

            <Spinner
                android:id="@+id/spReminderUnit"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:dropDownWidth="200dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Hiển thị thời gian nhắc nhở tính được -->
    <TextView
        android:id="@+id/tvReminderPreview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Thời gian nhắc nhở: --"
        android:textColor="@color/blue_primary"
        android:textSize="14sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="20dp"
        android:background="#33FFFFFF" />

    <!-- Nút Lưu và Hủy -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnCancelReminder"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:text="Hủy"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <View
            android:layout_width="12dp"
            android:layout_height="0dp" />

        <TextView
            android:id="@+id/btnSaveReminder"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@drawable/btn_outline"
            android:backgroundTint="@color/blue_primary"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:text="Lưu"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
