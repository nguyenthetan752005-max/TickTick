<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/themeBgDark">

    <!-- Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbarContacts"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:paddingHorizontal="@dimen/spacing_l"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="@dimen/icon_size_default"
            android:layout_height="@dimen/icon_size_default"
            android:src="@android:drawable/ic_menu_revert"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/themeTextWhite" />

        <TextView
            android:id="@+id/tvContactsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_l"
            android:text="@string/title_contacts"
            android:textColor="?attr/themeTextWhite"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- My Number -->
    <TextView
        android:id="@+id/tvMyNumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_l"
        android:layout_marginTop="@dimen/spacing_s"
        android:text="Số của máy này: Đang lấy..."
        android:textColor="?attr/themeTextWhite"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/toolbarContacts" />

    <!-- Search Bar -->
    <EditText
        android:id="@+id/etSearchContacts"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height_default"
        android:layout_marginHorizontal="@dimen/spacing_l"
        android:layout_marginTop="@dimen/spacing_s"
        android:background="@drawable/btn_outline"
        android:drawableStart="@android:drawable/ic_menu_search"
        android:drawablePadding="@dimen/spacing_s"
        android:drawableTint="?attr/themeTextSecondary"
        android:hint="@string/search_contacts"
        android:inputType="text"
        android:paddingHorizontal="@dimen/spacing_m"
        android:textColor="?attr/themeTextWhite"
        android:textColorHint="?attr/themeTextSecondary"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tvMyNumber" />

    <!-- Manual Entry -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutManual"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_l"
        android:layout_marginTop="@dimen/spacing_m"
        android:background="@drawable/btn_outline"
        android:paddingHorizontal="@dimen/spacing_m"
        android:paddingVertical="@dimen/spacing_s"
        app:layout_constraintTop_toBottomOf="@id/etSearchContacts">

        <EditText
            android:id="@+id/etManualPhone"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:background="@null"
            android:hint="Nhập số tự do để gọi/nhắn..."
            android:inputType="phone"
            android:textColor="?attr/themeTextWhite"
            android:textColorHint="?attr/themeTextSecondary"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnManualCall"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btnManualCall"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="@dimen/spacing_m"
            android:background="@drawable/item_circle_bg"
            android:backgroundTint="@color/green_call"
            android:padding="8dp"
            android:src="@android:drawable/sym_action_call"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnManualSms"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/themeTextWhite" />

        <ImageView
            android:id="@+id/btnManualSms"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/item_circle_bg"
            android:backgroundTint="@color/orange_sms"
            android:padding="8dp"
            android:src="@android:drawable/sym_action_email"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/themeTextWhite" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Contact List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvContacts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutManual" />

    <!-- Empty State -->
    <TextView
        android:id="@+id/tvEmptyContacts"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/no_contacts"
        android:textColor="?attr/themeTextSecondary"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutManual" />

</androidx.constraintlayout.widget.ConstraintLayout>
